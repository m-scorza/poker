# Normalize text files to LF in the index and working tree across Windows/WSL/macOS.
# Ends the Hermes/Antigravity CRLF vs LF whitespace war.
* text=auto eol=lf

# Explicitly mark text files to be normalized to LF
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sh text eol=lf
*.html text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf
.claudeignore text eol=lf

# Explicitly mark binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary

